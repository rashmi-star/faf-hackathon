# Must match agent/.env.local exactly. Local dev needs no LiveKit account —
# run `livekit-server --dev` and use these values as-is.
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Explicit agent dispatch; must match agent_name in agent/src/agent.py.
# Leave blank for automatic dispatch.
AGENT_NAME=my-agent

# LiveKit — local dev needs NO account. Run `livekit-server --dev` and use:
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
# (LiveKit Cloud alternative: cloud.livekit.io -> project -> keys)

# LLM (Anthropic Claude; primary model claude-fable-5)
ANTHROPIC_API_KEY=
# DIRECTOR_LLM_MODEL=claude-sonnet-5   # fallback if claude-fable-5 unavailable

# TTS + dialogue lines (ElevenLabs Flash v2.5)
ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9

# Media generation (fal)
FAL_KEY=

# STT (Deepgram; or swap to ElevenLabs Scribe in agent.py)
DEEPGRAM_API_KEY=

# DEV/TEST ONLY. Off by default: with keys present, the agent makes real fal +
# ElevenLabs calls. Set MOCK_MEDIA=1 only to rehearse the flow without spending
# credits — it returns bundled placeholder media. Never used in the shipped path.
# MOCK_MEDIA=1
# MOCK_ASSET_BASE_URL=http://localhost:3000

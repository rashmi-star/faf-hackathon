# LiveKit — local dev needs NO account. Run `livekit-server --dev` and use:
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
# (LiveKit Cloud alternative: cloud.livekit.io -> project -> keys)

# TTS + dialogue lines (ElevenLabs Flash v2.5)
ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9

# Director LLM + media generation (fal)
FAL_KEY=
# FAL_LLM_MODEL=google/gemini-2.5-flash-lite
# DIRECTOR_EXPORT_BASE_URL=/api/exports

# Speech recognition. "elevenlabs" reuses ELEVENLABS_API_KEY and is the
# simplest setup. Use "deepgram" only when DEEPGRAM_API_KEY is configured.
DIRECTOR_STT=elevenlabs
# DEEPGRAM_API_KEY=

# Local LiveKit does not support the Cloud-only ai-coustics service.
DIRECTOR_NOISE_CANCELLATION=0

# DEV/TEST ONLY. Off by default: with keys present, the agent makes real fal +
# ElevenLabs calls. Set MOCK_MEDIA=1 only to rehearse the flow without spending
# credits — it returns bundled placeholder media. Never used in the shipped path.
# MOCK_MEDIA=1
# MOCK_ASSET_BASE_URL=http://localhost:3000
